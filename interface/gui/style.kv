#:import components interface.gui.components
#:import utils kivy.utils
#:set main_color utils.get_color_from_hex('#d8d8d8')
#:set bright_color utils.get_color_from_hex('#e8e8e8')
#:set accent_color utils.get_color_from_hex('#8e8e8e')
#:set text_color utils.get_color_from_hex('#000000')
#:import platform kivy.utils.platform

# --- Fonts ---

<Label>:
    font_name: "UMTypewriter"

<Button>:
    font_name: "UMTypewriter"

<TextInput>:
    font_name: "UMTypewriter"

# --- Mixins ---

<ColoredWidget>:
    bg_color: main_color
    canvas.before:
        Color:
            rgba: self.bg_color
        Rectangle:
            pos: self.pos
            size: self.size

<CoverImage>:
    fit_mode: "cover"

# --- Reusable ---

<StyledLabel>:
    halign: "center"
    valign: "center"
    text_size: self.size
    color: text_color

# --- Smart ---

<Menu>:
    bg_color: main_color
    do_scroll_x: False
    spacing: dp(2)
    cols: 2
    GridLayout:
        id: container
        cols: root.cols
        orientation: 'lr-tb'
        spacing: [root.spacing, root.spacing]
        padding: [root.spacing, root.spacing]
        size_hint_y: None
        height: int(self.minimum_height)

<MenuItem>:
    size_hint_y: None
    height: dp(40)
    text_size: (self.width - dp(10), None)
    padding: [dp(5), dp(5)]
    halign: "center"
    valign: 'middle'
    background_normal: ''
    background_down: ''
    background_color: accent_color if self.state == 'down' else bright_color
    color: text_color

<LogView>:
    do_scroll_x: False
    bg_color: main_color
    viewclass: "LogBody"
    spacing: dp(5)
    font_size: sp(15)
    RecycleBoxLayout:
        id: container
        spacing: root.spacing
        orientation: 'vertical'
        size_hint_y: None
        height: self.minimum_height
        scroll_timeout: 0
        scroll_distance: 0

        default_size_hint: 1, None

<TimeBadge>:
    size_hint_x: None
    width: self.w
    halign: "center"
    valign: 'middle'
    color: text_color
    bg_color: bright_color if self.text == "" else accent_color

<LogEntry>:
    size_hint_y: 1.0
    size_hint_x: 1.0
    text_size: (self.width - self.p, None)
    halign: "center"
    valign: 'middle'
    bg_color: bright_color
    color: text_color

<LogBody>:
    orientation: "horizontal"
    size_hint_y: None
    height: self.height

    TimeBadge:
        text: root.badge_text
        font_size: root.font_size
        size_hint_y: 1.0

    LogEntry:
        id: entry
        text: root.entry_text
        font_size: root.font_size

<GameButton>:
    size_hint_y: None
    height: dp(50)
    background_normal: ''
    background_down: ''
    background_color: accent_color
    color: text_color
    text: "Action button"

<VolumeSlider>:
    min: 0
    max: 100
    step: 1
    value: app.volume
    on_value: app.volume = self.value
    track_color: main_color
    track_height: dp(10)
    cursor_color: main_color
    custom_cursor_size: dp(30)

<SceneView>:
    bg: ""
    sprite: ""
    border: dp(5)

    padding: self.border
    bg_color: accent_color

    FloatLayout:

        Image:
            source: root.bg
            fit_mode: "cover"
            size_hint: (1, 1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

        Image:
            source: root.sprite
            fit_mode: "contain"
            size_hint: (0.5, 0.5)
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}

<StatLabel>:
    name: "харизма"
    value: 0
    font_size_name: dp(15)
    font_size_value: dp(20)

    BoxLayout:
        orientation: "horizontal"
        StyledLabel:
            size_hint_x: 0.2
            halign: "center"
            color: text_color
            bg_color: accent_color
            text: str(root.value)
            font_size: root.font_size_value
            font_name: "UMTypewriter_bold"
        StyledLabel:
            size_hint_x: 0.8
            halign: "center"
            color: text_color
            bg_color: bright_color
            text: root.name
            font_size: root.font_size_name
            font_name: "UMTypewriter_bold"

<ImageButton>:
    padding: self.height / 5

    background_normal: ''
    background_down: ''
    normal_color: bright_color
    pressed_color: accent_color
    background_color: self.pressed_color if self.state == 'down' else self.normal_color

    RelativeLayout:
        pos: root.pos
        size: root.size

        Image:
            source: root.icon_source
            fit_mode: "contain"
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            size_hint: (None, None)
            size: (root.width - root.padding[0] * 2, root.height - root.padding[0] * 2)
            color: [0.8, 0.8, 0.8, 1] if root.state == 'down' else [1, 1, 1, 1]

MainScreen:
    source: "assets/images/ui/app_bg.png"
    orientation: "horizontal"

    padding: self.space_2
    spacing: self.space_3

    BoxLayout:
        orientation: "vertical"
        size_hint_x: 0.3
        spacing: root.space_1
        StyledBoxLayout:
            orientation: "vertical"
            size_hint_y: 0.2
            bg_color: main_color
            padding: root.space_1
            spacing: root.space_1
            BoxLayout:
                spacing: root.space_1
                id: system_buttons_box
                ImageButton:
                    id: fullscreen_button
                    on_release: app.toggle_fullscreen()
                    icon_source: "assets/images/ui/windowed.png" if app.fullscreen else "assets/images/ui/fullscreen.png"
                ImageButton
                    id: save_button
                    on_release: app.prevent_double_click(app.save_game)()
                    disabled: not app.system_buttons_active
                    icon_source: "assets/images/ui/save.png"
                ImageButton
                    id: exit_button
                    on_release: app.prevent_double_click(app.exit_game)()
                    disabled: not app.system_buttons_active
                    icon_source: "assets/images/ui/exit.png"
#                ImageButton
#                    id: achievements_button
#                    icon_source: "assets/images/ui/achievements.png"
            StyledBoxLayout:
                orientation: "horizontal"
                spacing: root.space_1
                ImageButton:
                    size_hint_y: 1
                    size_hint_x: None
                    width: self.height
                    icon_source: "assets/images/ui/mute.png" if app.muted else "assets/images/ui/volume.png"
                    on_release: app.prevent_double_click(app.toggle_mute)()
                StyledBoxLayout:
                    bg_color: bright_color
                    padding: root.space_1
                    VolumeSlider:
                        track_height: self.height / 12
                        custom_cursor_size: self.height / 2.5
        SceneView:
            id: scene
            size_hint_x: 1
            size_hint_y: None
            height: self.width
            border: root.space_1
        StyledBoxLayout:
            size_hint_y: 0.3
            orientation: "vertical"
            spacing: root.space_1
            padding: root.space_1
            StatLabel:
                name: "кредиты"
                id: money_stat_label
                font_size_name: root.text_md
            StatLabel:
                name: "знания"
                id: knowledge_stat_label
                font_size_name: root.text_md
            StatLabel:
                name: "харизма"
                id: social_stat_label
                font_size_name: root.text_md
    BoxLayout:
        orientation: "vertical"
        size_hint_x: 0.5
        spacing: root.space_1
        StyledBoxLayout:
            padding: root.space_sm
            size_hint_y: 0.6
            LogView:
                id: logger
                spacing: root.space_1
                font_size: root.text_sm
        Menu:
            id: menu
            size_hint_y: 0.4
            spacing: root.space_sm
            font_size: root.text_sm
        GameButton:
            id: button
            font_size: root.text_md
            font_name: "UMTypewriter_bold"
    BoxLayout:
        orientation: "vertical"
        size_hint_x: 0.2
        spacing: root.space_1
        StyledBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            padding: root.space_2
            spacing: root.space_1
            bg_color: main_color
            StyledLabel:
                id: date_label
                halign: 'center'
                text_size: (self.width, None)
                font_name: "UMTypewriter_bold"
                font_size: root.text_md
                size_hint_y: None
                height: self.texture_size[1]
                bg_color: (0, 0, 0, 0)
            StyledLabel:
                id: time_label
                halign: 'center'
                text_size: (self.width, None)
                font_name: "UMTypewriter_bold"
                font_size: root.text_md
                size_hint_y: None
                height: self.texture_size[1]
                bg_color: (0, 0, 0, 0)
        RelativeLayout:
            size_hint_y: 1
            StyledBoxLayout:
                orientation: "vertical"
                padding: root.space_1
                spacing: root.space_1
                size_hint_y: None
                height: self.minimum_height
                pos_hint: {'center_y': 0.5}
                Image:
                    source: "assets/images/ui/map.png"
                    bg_color: accent_color
                    size_hint_x: 1
                    size_hint_y: 1
                    fit_mode: "contain"
                    size_hint_y: None
                    height: (self.width / self.texture_size[0]) * self.texture_size[1] if self.texture_size else dp(100)